# .dockerignore — Exclude non-essential files from Docker build context
# Used by image/Dockerfile.build for ARM64 binary compilation.
# Only Go source, go.mod/go.sum, embed inputs, and stub scripts are needed.

# Exclude everything by default, then whitelist what we need
*

# Go source tree
!go.mod
!go.sum
!cmd/
!internal/
!assets.go
!static/

# Exclude test pcap/data from internal (large binary files)
internal/lidar/perf/pcap/

# Web frontend (built assets embedded via //go:embed web/build/*)
!web/build/
!web/stub-index.html
!scripts/ensure-web-stub.sh

# Embedded offline docs (built before image binaries are compiled)
!docs_html/
!docs_html/_site/
!docs_html/_site/**
!docs_html/stub-index.html
!scripts/ensure-docs-stub.sh
