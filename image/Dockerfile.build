# Dockerfile.build — Cross-compile velocity.report ARM64 binaries with pcap
#
# This image provides a native Linux environment with libpcap-dev for
# ARM64 cross-compilation, avoiding the need for aarch64-linux-gnu-gcc
# on macOS. The container builds velocity-report (with pcap) and
# velocity-ctl, then copies the binaries out.
#
# Usage (called by build-image.sh, not directly):
#   docker build -f image/Dockerfile.build -t velocity-builder .
#   docker run --rm -v $PWD/image/velocity-binaries:/out velocity-builder

FROM golang:1.25-bookworm

# Install ARM64 cross-compilation toolchain and libpcap headers
RUN dpkg --add-architecture arm64 && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    gcc-aarch64-linux-gnu \
    libc6-dev-arm64-cross \
    libpcap-dev:arm64 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy go.mod and go.sum first for layer caching
COPY go.mod go.sum ./
RUN go mod download

# Copy the full source tree
COPY . .

# Ensure embed stubs exist for direct Dockerfile builds. The image build script
# performs the full web and offline-docs builds before invoking Docker.
RUN ./scripts/ensure-web-stub.sh
RUN ./scripts/ensure-docs-stub.sh

# Version metadata passed at build time
ARG VERSION=dev
ARG GIT_SHA=unknown
ARG BUILD_TIME=unknown

# Build ARM64 binaries with pcap support
ENV CGO_ENABLED=1 \
    GOOS=linux \
    GOARCH=arm64 \
    CC=aarch64-linux-gnu-gcc \
    PKG_CONFIG_PATH=/usr/lib/aarch64-linux-gnu/pkgconfig

RUN go build -tags=pcap -ldflags "-s -w \
    -X 'github.com/banshee-data/velocity.report/internal/version.Version=${VERSION}' \
    -X 'github.com/banshee-data/velocity.report/internal/version.GitSHA=${GIT_SHA}' \
    -X 'github.com/banshee-data/velocity.report/internal/version.BuildTime=${BUILD_TIME}'" \
    -o /out/velocity-report ./cmd/radar

RUN go build -ldflags "-s -w \
    -X 'github.com/banshee-data/velocity.report/internal/version.Version=${VERSION}' \
    -X 'github.com/banshee-data/velocity.report/internal/version.GitSHA=${GIT_SHA}' \
    -X 'github.com/banshee-data/velocity.report/internal/version.BuildTime=${BUILD_TIME}'" \
    -o /out/velocity-ctl ./cmd/velocity-ctl
