# /etc/udev/rules.d/99-velocity-report.rules
# USB-Serial adapter for OmniPreSense OPS243 radar
# Creates /dev/velocity-radar symlink and starts velocity-report.service
# when the device is connected. The service stops when the device is removed
# (via BindsTo= in the service unit).
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", MODE="0666", SYMLINK+="velocity-radar", TAG+="systemd", ENV{SYSTEMD_WANTS}+="velocity-report.service"
