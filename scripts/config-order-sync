#!/usr/bin/env python3
"""Synchronise and validate canonical nested tuning key order."""

from __future__ import annotations

import argparse
import copy
import json
import re
import sys
from collections import OrderedDict
from dataclasses import dataclass
from pathlib import Path


@dataclass
class MarkdownJSONBlock:
    start: int
    end: int
    obj: OrderedDict


def load_json_object(path: Path) -> OrderedDict:
    with path.open("r", encoding="utf-8") as handle:
        data = json.load(handle, object_pairs_hook=OrderedDict)
    if not isinstance(data, dict):
        raise ValueError(f"{path}: expected top-level JSON object")
    return data


def write_json_object(path: Path, obj: OrderedDict) -> None:
    path.write_text(json.dumps(obj, indent=2) + "\n", encoding="utf-8")


def parse_markdown_json_blocks(text: str, path: Path) -> list[MarkdownJSONBlock]:
    blocks: list[MarkdownJSONBlock] = []
    for match in re.finditer(r"```json[ \t]*\n(.*?)\n```", text, flags=re.DOTALL):
        raw = match.group(1)
        try:
            parsed = json.loads(raw, object_pairs_hook=OrderedDict)
        except json.JSONDecodeError as exc:
            raise ValueError(f"{path}: invalid JSON block: {exc}") from exc
        if isinstance(parsed, dict):
            blocks.append(MarkdownJSONBlock(match.start(1), match.end(1), parsed))
    if not blocks:
        raise ValueError(f"{path}: no parseable ```json``` object blocks found")
    return blocks


def normalize_source_path(path: str, cwd: Path) -> Path:
    candidate = Path(path)
    if not candidate.is_absolute():
        candidate = cwd / candidate
    return candidate.resolve()


def parse_go_source(source: str) -> tuple[str, str]:
    if ":" not in source:
        raise ValueError("--main-go-struct expects PATH:STRUCT")
    path, struct_name = source.rsplit(":", 1)
    if not path or not struct_name:
        raise ValueError("--main-go-struct expects PATH:STRUCT")
    return path, struct_name


def discover_targets(cwd: Path, md_targets: set[Path], json_targets: set[Path]) -> None:
    for path in sorted((cwd / "config").glob("tuning*.json")):
        if path.is_file():
            json_targets.add(path.resolve())
    for path in sorted((cwd / "config").glob("*.md")):
        if path.is_file():
            md_targets.add(path.resolve())


def extract_keys_from_go_struct(path: Path, struct_name: str) -> list[str]:
    lines = path.read_text(encoding="utf-8").splitlines()
    start_re = re.compile(rf"^\s*type\s+{re.escape(struct_name)}\s+struct\s*\{{\s*$")
    tag_re = re.compile(r'`json:"([^",]+)')

    in_struct = False
    keys: list[str] = []
    seen: set[str] = set()
    for line in lines:
        if not in_struct:
            if start_re.match(line):
                in_struct = True
            continue
        if line.strip() == "}":
            break
        match = tag_re.search(line)
        if not match:
            continue
        key = match.group(1)
        if key == "-" or key in seen:
            continue
        seen.add(key)
        keys.append(key)

    if not in_struct:
        raise ValueError(f"{path}: struct {struct_name} not found")
    if not keys:
        raise ValueError(f"{path}: no json tags found in struct {struct_name}")
    return keys


def flatten_leaf_paths(obj: object, prefix: str = "") -> list[str]:
    if isinstance(obj, dict):
        paths: list[str] = []
        for key, value in obj.items():
            if prefix == "" and str(key).startswith("_"):
                continue
            path = f"{prefix}.{key}" if prefix else str(key)
            if isinstance(value, dict):
                paths.extend(flatten_leaf_paths(value, path))
            else:
                paths.append(path)
        return paths
    if prefix:
        return [prefix]
    return []


def choose_best_markdown_block(blocks: list[MarkdownJSONBlock], canonical_obj: OrderedDict) -> MarkdownJSONBlock:
    canonical_paths = set(flatten_leaf_paths(canonical_obj))
    best: MarkdownJSONBlock | None = None
    best_score = -1
    for block in blocks:
        score = len([path for path in flatten_leaf_paths(block.obj) if path in canonical_paths])
        if score > best_score:
            best = block
            best_score = score
    if best is None:
        raise ValueError("internal error: unable to select markdown JSON block")
    return best


def nested_key_status(existing: OrderedDict, canonical: OrderedDict) -> tuple[list[str], list[str], bool]:
    existing_paths = flatten_leaf_paths(existing)
    canonical_paths = flatten_leaf_paths(canonical)
    existing_set = set(existing_paths)
    canonical_set = set(canonical_paths)
    missing = [path for path in canonical_paths if path not in existing_set]
    extra = [path for path in existing_paths if path not in canonical_set]
    filtered = [path for path in existing_paths if path in canonical_set]
    expected = [path for path in canonical_paths if path in existing_set]
    return missing, extra, filtered == expected


def clone_json_value(value: object) -> object:
    return copy.deepcopy(value)


def reorder_object(
    existing: OrderedDict,
    canonical: OrderedDict,
    *,
    fill_missing: bool,
    prefix: str = "",
) -> tuple[OrderedDict, list[str]]:
    out: OrderedDict = OrderedDict()
    missing: list[str] = []

    if prefix == "":
        for key in existing:
            if str(key).startswith("_") and key not in canonical:
                out[key] = existing[key]

    for key, canonical_value in canonical.items():
        path = f"{prefix}.{key}" if prefix else str(key)
        if key not in existing:
            if fill_missing:
                out[key] = clone_json_value(canonical_value)
            else:
                missing.extend(flatten_leaf_paths(canonical_value, path))
            continue

        existing_value = existing[key]
        if isinstance(canonical_value, dict):
            if isinstance(existing_value, dict):
                child, child_missing = reorder_object(
                    existing_value,
                    canonical_value,
                    fill_missing=fill_missing,
                    prefix=path,
                )
                out[key] = child
                missing.extend(child_missing)
            elif fill_missing:
                out[key] = clone_json_value(canonical_value)
            else:
                missing.extend(flatten_leaf_paths(canonical_value, path))
        else:
            out[key] = existing_value

    for key in existing:
        if key in canonical:
            continue
        if prefix == "" and str(key).startswith("_"):
            continue
        out[key] = existing[key]

    return out, missing


def apply_json_target(
    path: Path,
    canonical_obj: OrderedDict,
    *,
    check_only: bool,
) -> tuple[bool, bool, str]:
    try:
        obj = load_json_object(path)
    except Exception as err:  # noqa: BLE001
        return False, False, f"[FAIL] {path}: {err}"

    missing, extra, order_ok = nested_key_status(obj, canonical_obj)
    issues: list[str] = []
    if missing:
        issues.append(f"missing keys: {', '.join(missing)}")
    if extra:
        issues.append(f"extra keys: {', '.join(extra)}")
    if not order_ok:
        issues.append("canonical leaf-key order mismatch")

    if check_only:
        if issues:
            return False, False, f"[FAIL] {path}: " + "; ".join(issues)
        return True, False, f"[OK] {path}"

    ordered, still_missing = reorder_object(obj, canonical_obj, fill_missing=True)
    if still_missing:
        return False, False, f"[FAIL] {path}: cannot sync missing keys: {', '.join(still_missing)}"
    changed = ordered != obj
    if changed:
        write_json_object(path, ordered)
        return True, True, f"[SYNC] {path}"
    return True, False, f"[OK] {path}"


def apply_markdown_target(
    path: Path,
    canonical_obj: OrderedDict,
    *,
    check_only: bool,
) -> tuple[bool, bool, str]:
    try:
        text = path.read_text(encoding="utf-8")
        blocks = parse_markdown_json_blocks(text, path)
        block = choose_best_markdown_block(blocks, canonical_obj)
    except Exception as err:  # noqa: BLE001
        return False, False, f"[FAIL] {path}: {err}"

    missing, extra, order_ok = nested_key_status(block.obj, canonical_obj)
    issues: list[str] = []
    if missing:
        issues.append(f"missing keys: {', '.join(missing)}")
    if extra:
        issues.append(f"extra keys: {', '.join(extra)}")
    if not order_ok:
        issues.append("canonical leaf-key order mismatch")

    if check_only:
        if issues:
            return False, False, f"[FAIL] {path}: " + "; ".join(issues)
        return True, False, f"[OK] {path}"

    ordered, still_missing = reorder_object(block.obj, canonical_obj, fill_missing=True)
    if still_missing:
        return False, False, f"[FAIL] {path}: cannot sync missing keys: {', '.join(still_missing)}"

    block_text = json.dumps(ordered, indent=2)
    new_text = text[: block.start] + block_text + text[block.end :]
    changed = new_text != text
    if changed:
        path.write_text(new_text, encoding="utf-8")
        return True, True, f"[SYNC] {path}"
    return True, False, f"[OK] {path}"


def main() -> int:
    parser = argparse.ArgumentParser(description="Ensure consistent nested tuning key order across config sources.")
    main_group = parser.add_mutually_exclusive_group(required=True)
    main_group.add_argument("--main-json", help="Canonical source JSON object file.")
    main_group.add_argument("--main-go-struct", help="Canonical source Go struct in PATH:STRUCT format.")
    main_group.add_argument("--main-md", help="Canonical source markdown file containing a JSON code block.")
    parser.add_argument("--json-target", action="append", default=[], help="JSON file target to validate/sync.")
    parser.add_argument("--md-target", action="append", default=[], help="Markdown target containing a JSON block.")
    parser.add_argument("--discover", action="store_true", help="Auto-discover config targets in ./config.")
    parser.add_argument("--check", action="store_true", help="Check only (non-mutating).")
    args = parser.parse_args()

    cwd = Path.cwd().resolve()

    try:
        if args.main_json:
            main_path = normalize_source_path(args.main_json, cwd)
            canonical_obj = load_json_object(main_path)
        elif args.main_md:
            main_path = normalize_source_path(args.main_md, cwd)
            blocks = parse_markdown_json_blocks(main_path.read_text(encoding="utf-8"), main_path)
            canonical_obj = blocks[0].obj
        else:
            rel_path, struct_name = parse_go_source(args.main_go_struct)
            main_path = normalize_source_path(rel_path, cwd)
            canonical_obj = OrderedDict((key, None) for key in extract_keys_from_go_struct(main_path, struct_name))
    except Exception as err:  # noqa: BLE001
        print(f"error: failed to load canonical source: {err}", file=sys.stderr)
        return 2

    json_targets: set[Path] = {normalize_source_path(path, cwd) for path in args.json_target}
    md_targets: set[Path] = {normalize_source_path(path, cwd) for path in args.md_target}

    if args.discover:
        discover_targets(cwd, md_targets, json_targets)

    json_targets.discard(main_path)
    md_targets.discard(main_path)

    filtered_md_targets: set[Path] = set()
    explicit_md_targets = {normalize_source_path(path, cwd) for path in args.md_target}
    explicit_md_failures: list[str] = []
    for md_path in sorted(md_targets):
        try:
            blocks = parse_markdown_json_blocks(md_path.read_text(encoding="utf-8"), md_path)
            choose_best_markdown_block(blocks, canonical_obj)
            filtered_md_targets.add(md_path)
        except Exception as err:  # noqa: BLE001
            if md_path in explicit_md_targets:
                explicit_md_failures.append(f"[FAIL] {md_path}: {err}")

    if explicit_md_failures:
        for message in explicit_md_failures:
            print(message, file=sys.stderr)
        return 1

    if not json_targets and not filtered_md_targets:
        print("error: no targets selected (use --json-target/--md-target and/or --discover)", file=sys.stderr)
        return 2

    failed = False
    changed_count = 0

    for json_path in sorted(json_targets):
        ok, changed, msg = apply_json_target(json_path, canonical_obj, check_only=args.check)
        print(msg)
        failed = failed or not ok
        changed_count += int(changed)

    for md_path in sorted(filtered_md_targets):
        ok, changed, msg = apply_markdown_target(md_path, canonical_obj, check_only=args.check)
        print(msg)
        failed = failed or not ok
        changed_count += int(changed)

    if failed:
        return 1
    if args.check:
        print("config key order check passed")
    else:
        print(f"config key order sync complete; updated {changed_count} file(s)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
