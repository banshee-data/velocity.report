#!/usr/bin/env python3
"""Validate README.maths leaf paths against tuning JSON and README examples."""

from __future__ import annotations

import argparse
import glob
import json
import re
import sys
from pathlib import Path


KEY_RE = re.compile(r"^[a-z0-9_.]+$")
JSON_BLOCK_RE = re.compile(r"```json[ \t]*\n(.*?)\n```", re.DOTALL)


def is_valid_key(key: str, *, allow_private: bool) -> bool:
    if not KEY_RE.fullmatch(key):
        return False
    if not allow_private and key.startswith("_"):
        return False
    return True


def unique_preserve_order(keys: list[str]) -> list[str]:
    out: list[str] = []
    seen: set[str] = set()
    for key in keys:
        if key in seen:
            continue
        seen.add(key)
        out.append(key)
    return out


def extract_maths_keys(path: Path) -> list[str]:
    keys: list[str] = []
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line.startswith("- "):
            continue
        body = line[2:].strip()
        if not body.startswith("`"):
            continue
        end = body.find("`", 1)
        if end <= 1:
            continue
        token = body[1:end].strip()
        if is_valid_key(token, allow_private=True):
            keys.append(token)
    keys = unique_preserve_order(keys)
    if not keys:
        raise ValueError(f"{path}: no config paths found")
    return keys


def flatten_leaf_paths(value: object, prefix: str = "") -> list[str]:
    if isinstance(value, dict):
        out: list[str] = []
        for key, child in value.items():
            if prefix == "" and str(key).startswith("_"):
                continue
            path = f"{prefix}.{key}" if prefix else str(key)
            if isinstance(child, dict):
                out.extend(flatten_leaf_paths(child, path))
            else:
                out.append(path)
        return out
    if prefix:
        return [prefix]
    return []


def extract_json_blocks(path: Path) -> list[dict]:
    text = path.read_text(encoding="utf-8")
    blocks: list[dict] = []
    for match in JSON_BLOCK_RE.finditer(text):
        raw = match.group(1)
        try:
            parsed = json.loads(raw)
        except json.JSONDecodeError as exc:
            line = text[: match.start(1)].count("\n") + 1
            raise ValueError(f"{path}: invalid JSON block at line {line}: {exc}") from exc
        if isinstance(parsed, dict):
            blocks.append(parsed)
    return blocks


def expand_globs(root: Path, patterns: list[str]) -> list[Path]:
    out: list[Path] = []
    seen: set[Path] = set()
    for pattern in patterns:
        glob_pattern = pattern if Path(pattern).is_absolute() else str(root / pattern)
        for match in sorted(glob.glob(glob_pattern, recursive=True)):
            path = Path(match).resolve()
            if not path.is_file() or path in seen:
                continue
            seen.add(path)
            out.append(path)
    return out


def compare_key_sets(label: str, source_keys: list[str], maths_keys: list[str]) -> bool:
    source_set = set(source_keys)
    maths_set = set(maths_keys)
    source_only = sorted(source_set - maths_set)
    maths_only = sorted(maths_set - source_set)
    if source_only or maths_only:
        print(f"[FAIL] {label}: key mismatch")
        if source_only:
            print(f"  - present in source, missing in maths list: {', '.join(source_only)}")
        if maths_only:
            print(f"  - present in maths list, missing in source: {', '.join(maths_only)}")
        return False
    print(f"[OK] {label}: keys match ({len(source_keys)})")
    return True


def main() -> int:
    parser = argparse.ArgumentParser(description="Check README.maths leaf paths against docs and tuning JSON")
    parser.add_argument("--maths-md", default="config/README.maths.md")
    parser.add_argument("--doc-md", action="append", default=["config/README.md"])
    parser.add_argument("--doc-glob", action="append", default=[])
    parser.add_argument("--require-key", default="version")
    parser.add_argument("--tuning-json-glob", action="append", default=["config/tuning*.json"])
    parser.add_argument("--webserver-mode", choices=["subset", "exact"], default="exact")
    args = parser.parse_args()

    root = Path.cwd().resolve()
    maths_path = (root / args.maths_md).resolve()
    doc_paths = [(root / path).resolve() for path in args.doc_md]
    for path in expand_globs(root, args.doc_glob):
        if path not in doc_paths:
            doc_paths.append(path)
    tuning_paths = expand_globs(root, args.tuning_json_glob)

    try:
        maths_keys = extract_maths_keys(maths_path)
    except Exception as err:  # noqa: BLE001
        print(f"[FAIL] {err}", file=sys.stderr)
        return 1

    print(f"[OK] {maths_path}: extracted {len(maths_keys)} config paths")
    failed = False

    for doc_path in doc_paths:
        try:
            blocks = extract_json_blocks(doc_path)
        except Exception as err:  # noqa: BLE001
            print(f"[FAIL] {err}")
            failed = True
            continue
        selected = [block for block in blocks if args.require_key in block]
        if not selected:
            print(f"[FAIL] {doc_path}: no JSON block contains required key '{args.require_key}'")
            failed = True
            continue
        for index, block in enumerate(selected, start=1):
            ok = compare_key_sets(f"{doc_path} block#{index}", flatten_leaf_paths(block), maths_keys)
            if not ok:
                failed = True

    if not tuning_paths:
        print(f"[FAIL] no tuning JSON files matched: {', '.join(args.tuning_json_glob)}")
        failed = True
    else:
        for tuning_path in tuning_paths:
            try:
                parsed = json.loads(tuning_path.read_text(encoding="utf-8"))
            except json.JSONDecodeError as err:
                print(f"[FAIL] {tuning_path}: invalid JSON ({err})")
                failed = True
                continue
            if not isinstance(parsed, dict):
                print(f"[FAIL] {tuning_path}: expected top-level JSON object")
                failed = True
                continue
            ok = compare_key_sets(str(tuning_path), flatten_leaf_paths(parsed), maths_keys)
            if not ok:
                failed = True

    if failed:
        return 1
    print("README maths source checks passed")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
