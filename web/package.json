{
	"name": "velocity.report-web",
	"private": true,
	"version": "0.5.1-pre16",
	"type": "module",
	"license": "Apache-2.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"scripts": {
		"dev": "node scripts/set-build-env.js dev pnpm exec vite dev",
		"build": "node scripts/set-build-env.js build pnpm exec vite build",
		"postbuild": "node scripts/copy-build.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"up-deps": "pnpm update -r -i --latest",
		"format": "pnpm run prettier:write",
		"prettier:check": "prettier --check .",
		"prettier:write": "prettier --write .",
		"lint": "pnpm run prettier:check && pnpm exec eslint .",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --maxWorkers=2"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@layerstack/tailwind": "2.0.0-next.22",
		"@mdi/js": "^7.4.47",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/d3-scale": "^4.0.9",
		"@types/jest": "^30.0.0",
		"cross-env": "^10.1.0",
		"d3-scale": "4.0.2",
		"date-fns": "4.1.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"svelte-jester": "^5.0.0",
		"svelte-ux": "2.0.0-next.22",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.10"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild",
			"svelte-preprocess",
			"unrs-resolver"
		],
		"overrides": {
			"cookie@<0.7.0": "0.7.0",
			"devalue@<5.6.2": "5.6.2",
			"handlebars@<=4.7.8": "^4.7.9",
			"lodash-es@<=4.17.23": "^4.18.0",
			"picomatch@<2.3.2": "2.3.2"
		}
	},
	"dependencies": {
		"@layerstack/utils": "2.0.0-next.18",
		"@types/leaflet": "^1.9.21",
		"leaflet": "^1.9.4"
	}
}
